#!/usr/bin/env python3
# -*- coding: utf-8 -*-

import os
import time
import warnings
from typing import Dict, List, Optional

os.environ.setdefault("HF_HUB_OFFLINE", "1")
os.environ.setdefault("TRANSFORMERS_OFFLINE", "1")
os.environ.setdefault("TOKENIZERS_PARALLELISM", "false")
os.environ.setdefault("TRANSFORMERS_VERBOSITY", "error")

warnings.filterwarnings("ignore", message=".*Unused or unrecognized kwargs.*")

import numpy as np
from PIL import Image as PILImage

import torch
import torch.nn.functional as F
from transformers import CLIPSegProcessor, CLIPSegForImageSegmentation
from transformers.utils import logging as hf_logging

hf_logging.set_verbosity_error()

try:
    torch.set_num_threads(1)
except Exception:
    pass

try:
    torch.set_num_interop_threads(1)
except Exception:
    pass

try:
    if torch.cuda.is_available():
        torch.backends.cudnn.benchmark = True
except Exception:
    pass


class ClipsegCore:
    def __init__(
        self,
        model_dir: str,
        prompts: List[str],
        behavior_rule: str = "avoid_grass",
        device: Optional[str] = None,
        input_width: int = 224,
        confidence_threshold: float = 0.25,
        use_amp: bool = True,
        debug_mode: str = "raw",
        make_debug_overlay: bool = True,
    ):
        self.model_dir = model_dir
        self.prompts = list(prompts)
        self.behavior_rule = behavior_rule
        self.input_width = int(input_width)
        self.confidence_threshold = float(confidence_threshold)
        self.use_amp = bool(use_amp)
        self.debug_mode = debug_mode
        self.make_debug_overlay_enabled = bool(make_debug_overlay)

        if device is None:
            self.device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
        else:
            self.device = torch.device(device)

        if not os.path.isdir(self.model_dir):
            raise FileNotFoundError(f"Local CLIPSeg model directory not found: {self.model_dir}")

        self.processor = CLIPSegProcessor.from_pretrained(
            self.model_dir,
            local_files_only=True,
        )
        self.model = CLIPSegForImageSegmentation.from_pretrained(
            self.model_dir,
            local_files_only=True,
        ).to(self.device)
        self.model.eval()

        self.prompt_costs = self.build_prompt_costs(self.prompts, self.behavior_rule)

        self.inference_count = 0
        self.last_inference_time = 0.0
        self.last_total_time = 0.0

    @staticmethod
    def build_prompt_costs(prompts: List[str], behavior_rule: str) -> Dict[str, float]:
        rule = behavior_rule.lower().strip()
        costs: Dict[str, float] = {}

        for p in prompts:
            name = p.lower().strip()

            is_grass = ("grass" in name) or ("vegetation" in name) or ("lawn" in name)
            is_pavement = (
                ("pavement" in name)
                or ("sidewalk" in name)
                or ("road" in name)
                or ("concrete" in name)
                or ("floor" in name)
            )
            is_stop = ("stop" in name) or ("person" in name) or ("gesture" in name)

            if is_stop:
                costs[p] = 100.0
                continue

            if rule == "avoid_grass":
                if is_grass:
                    costs[p] = 80.0
                elif is_pavement:
                    costs[p] = 0.0
                else:
                    costs[p] = 30.0
            elif rule == "allow_grass":
                costs[p] = 0.0 if (is_grass or is_pavement) else 30.0
            elif rule == "prefer_pavement":
                if is_pavement:
                    costs[p] = 0.0
                elif is_grass:
                    costs[p] = 80.0
                else:
                    costs[p] = 40.0
            else:
                costs[p] = 80.0 if is_grass else (0.0 if is_pavement else 30.0)

        return costs

    @staticmethod
    def decode_rgb_image_msg(msg, copy: bool = True) -> np.ndarray:
        """Decode sensor_msgs/Image to an HxWx3 RGB array.

        copy=True is intentionally the default. In ROS 2 image pipelines on Jetson,
        zero-copy numpy views can keep the underlying Image buffer alive longer than
        intended. This function returns an independent C-contiguous array by default.
        """
        return ClipsegCore.decode_rgb_image_buffer(
            data=msg.data,
            width=int(msg.width),
            height=int(msg.height),
            step=int(msg.step),
            encoding=str(msg.encoding),
            copy=copy,
        )

    @staticmethod
    def decode_rgb_image_buffer(
        data,
        width: int,
        height: int,
        step: int,
        encoding: str,
        copy: bool = True,
    ) -> np.ndarray:
        encoding_l = encoding.lower()

        if encoding_l in ("rgb8", "bgr8"):
            channels = 3
        elif encoding_l in ("rgba8", "bgra8"):
            channels = 4
        elif encoding_l in ("mono8", "8uc1"):
            channels = 1
        else:
            raise ValueError(f"Unsupported RGB image encoding: {encoding}")

        expected_row_bytes = int(width) * channels
        expected_total_bytes = int(height) * int(step)

        if len(data) != expected_total_bytes:
            raise ValueError(
                f"Image data length mismatch: got {len(data)}, expected {expected_total_bytes}"
            )

        raw = np.frombuffer(data, dtype=np.uint8)

        if int(step) == expected_row_bytes:
            arr = raw.reshape(int(height), int(width), channels)
        else:
            rows = raw.reshape(int(height), int(step))
            useful = rows[:, :expected_row_bytes]
            arr = useful.reshape(int(height), int(width), channels)

        if encoding_l == "rgb8":
            rgb = arr
        elif encoding_l == "bgr8":
            rgb = arr[:, :, ::-1]
        elif encoding_l == "rgba8":
            rgb = arr[:, :, :3]
        elif encoding_l == "bgra8":
            rgb = arr[:, :, [2, 1, 0]]
        else:
            rgb = np.repeat(arr[:, :, :1], 3, axis=2)

        if copy:
            return np.array(rgb, dtype=np.uint8, copy=True, order="C")
        return np.ascontiguousarray(rgb)

    def infer_msg(self, msg):
        rgb = self.decode_rgb_image_msg(msg, copy=True)
        return self.infer_rgb_array(rgb)

    def infer_rgb_array(self, rgb: np.ndarray):
        total_start = time.time()

        if rgb.ndim != 3 or rgb.shape[2] != 3:
            raise ValueError(f"RGB image must be HxWx3, got shape={rgb.shape}")

        rgb = np.asarray(rgb, dtype=np.uint8, order="C")
        h, w = rgb.shape[:2]
        pil_image = PILImage.fromarray(rgb, mode="RGB")

        if self.input_width > 0 and w > self.input_width:
            new_w = int(self.input_width)
            new_h = max(1, int(round(h * (new_w / float(w)))))
            pil_for_model = pil_image.resize((new_w, new_h), resample=PILImage.BILINEAR)
        else:
            pil_for_model = pil_image

        inputs = self.processor(
            text=self.prompts,
            images=[pil_for_model] * len(self.prompts),
            return_tensors="pt",
            padding=True,
            truncation=True,
        )
        inputs = {k: v.to(self.device, non_blocking=True) for k, v in inputs.items()}

        infer_start = time.time()
        with torch.inference_mode():
            if self.use_amp and self.device.type == "cuda":
                with torch.autocast(device_type="cuda", dtype=torch.float16):
                    outputs = self.model(**inputs)
            else:
                outputs = self.model(**inputs)

            preds = torch.sigmoid(outputs.logits)
            preds_resized = F.interpolate(
                preds.unsqueeze(1),
                size=(h, w),
                mode="bilinear",
                align_corners=False,
            ).squeeze(1)

            # .cpu() is also the CUDA synchronization point for timing.
            probs = preds_resized.float().cpu().numpy().copy()

        raw_prob_map = self.probs_to_raw_map(probs)
        cost_map = self.probs_to_cost_map(probs)

        if self.make_debug_overlay_enabled:
            overlay_map = cost_map if self.debug_mode == "cost" else raw_prob_map
            debug_rgb = self.make_debug_overlay(rgb, overlay_map)
        else:
            debug_rgb = None

        self.last_inference_time = time.time() - infer_start
        self.last_total_time = time.time() - total_start
        self.inference_count += 1

        return {
            "debug_rgb": debug_rgb,
            "cost_map": cost_map,
            "raw_prob_map": raw_prob_map,
            "rgb_shape": rgb.shape,
            "inference_count": self.inference_count,
            "inference_time": self.last_inference_time,
            "total_time": self.last_total_time,
        }

    @staticmethod
    def probs_to_raw_map(probs: np.ndarray) -> np.ndarray:
        if probs.ndim != 3:
            raise ValueError(f"Expected CxHxW probs, got shape={probs.shape}")
        raw = np.max(probs, axis=0)
        return np.clip(raw * 100.0, 0, 100).astype(np.uint8)

    def probs_to_cost_map(self, probs: np.ndarray) -> np.ndarray:
        if probs.ndim != 3:
            raise ValueError(f"Expected CxHxW probs, got shape={probs.shape}")

        c, h, w = probs.shape
        cost_map = np.zeros((h, w), dtype=np.float32)

        for i, prompt in enumerate(self.prompts):
            if i >= c:
                break

            prompt_cost = float(self.prompt_costs.get(prompt, 0.0))
            if prompt_cost <= 0.0:
                continue

            p = probs[i]
            p = np.where(p >= self.confidence_threshold, p, 0.0)
            cost_map = np.maximum(cost_map, p * prompt_cost)

        return np.clip(cost_map, 0, 100).astype(np.uint8)

    @staticmethod
    def make_debug_overlay(rgb: np.ndarray, mask_map: np.ndarray, alpha: float = 0.55) -> np.ndarray:
        h, w = rgb.shape[:2]

        if mask_map.shape != (h, w):
            img = PILImage.fromarray(mask_map.astype(np.uint8), mode="L")
            mask_map = np.asarray(img.resize((w, h), resample=PILImage.BILINEAR), dtype=np.uint8)

        rgb_f = rgb.astype(np.float32)
        c = np.clip(mask_map.astype(np.float32) / 100.0, 0.0, 1.0)

        heat = np.zeros_like(rgb_f)
        heat[..., 0] = 255.0 * c
        heat[..., 1] = 180.0 * c
        heat[..., 2] = 20.0 * c

        mask = c > 0.01
        out = rgb_f.copy()
        out[mask] = (1.0 - alpha) * rgb_f[mask] + alpha * heat[mask]
        return np.clip(out, 0, 255).astype(np.uint8)
