<!-- 根标签，必须声明 xmlns:xacro -->
<robot name="car_base" xmlns:xacro="http://www.ros.org/wiki/xacro">
    <!-- 封装变量、常量 -->
    <xacro:property name="PI" value="3.1415926"/>
    <!-- 宏:黑色设置 -->
    <material name="black">
      <color rgba="0.0 0.0 0.0 1.0" />
    </material>
    <!-- 底盘属性 -->
    <xacro:property name="base_footprint_radius" value="0.001" /> <!-- base_footprint 半径  -->
    <xacro:property name="earth_space" value="0.145" /> <!-- 离地间距 -->
    <xacro:property name="base_link_height" value="0.25" /> <!-- 底盘高度 -->
    <xacro:property name="base_link_m" value="50" />
    <xacro:property name="base_link_back_m" value="20" /> 
    <xacro:property name="base_link_front_m" value="20" />

    <!-- Macro for inertia matrix -->
    <xacro:macro name="sphere_inertial_matrix" params="m r">
        <inertial>
            <mass value="${m}" />
            <inertia ixx="${2*m*r*r/5}" ixy="0" ixz="0"
                iyy="${2*m*r*r/5}" iyz="0" 
                izz="${2*m*r*r/5}" />
        </inertial>
    </xacro:macro>

    <xacro:macro name="cylinder_inertial_matrix" params="m r h">
        <inertial>
            <mass value="${m}" />
            <inertia ixx="${m*(3*r*r+h*h)/12}" ixy ="0" ixz ="0"
                iyy="${m*r*r/2}" iyz ="0"
                izz="${m*(3*r*r+h*h)/12}" /> 
        </inertial>
    </xacro:macro>

    <xacro:macro name="Box_inertial_matrix" params="m l w h">
       <inertial>
               <mass value="${m}" />
               <inertia ixx="${m*(h*h + l*l)/12}" ixy ="0" ixz ="0"
                   iyy="${m*(w*w + h*h)/12}" iyz="0"
                   izz="${m*(w*w + l*l)/12}" />
       </inertial>
   </xacro:macro>

    <!-- 底盘 -->
    <link name="base_footprint">
      <visual>
        <geometry>
          <sphere radius="${base_footprint_radius}" />
        </geometry>
      </visual>
    </link>

    <link name="base_link">
      <visual>
        <geometry>
          <box size="0.75 0.835 0.25" />
        </geometry>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <material name="yellow">
          <color rgba="0.5 0.3 0.0 1.0" />
        </material>
      </visual>
      <collision>
        <geometry>
          <box size="0.75 0.835 0.25" />
        </geometry>
        <origin xyz="0 0 0" rpy="0 0 0" />
      </collision>
      <xacro:Box_inertial_matrix m="${base_link_m}" l="0.75" w="0.835" h="0.25"/>
    </link>

    <link name="base_link_back">
      <visual>
        <geometry>
          <box size="0.4 0.26 0.25" />
        </geometry>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <material name="yellow">
          <color rgba="0.5 0.3 0.0 1.0" />
        </material>
      </visual>
      <collision>
        <geometry>
          <box size="0.4 0.26 0.25" />
        </geometry>
        <origin xyz="0 0 0" rpy="0 0 0" />
      </collision>
      <xacro:Box_inertial_matrix m="${base_link_back_m}" l="0.4" w="0.26" h="0.25"/>
    </link>

    <link name="base_link_front">
      <visual>
        <geometry>
          <box size="0.45 0.26 0.25" />
        </geometry>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <material name="yellow">
          <color rgba="0.5 0.3 0.0 1.0" />
        </material>
      </visual>
      <collision>
        <geometry>
          <box size="0.45 0.26 0.25" />
        </geometry>
        <origin xyz="0 0 0" rpy="0 0 0" />
      </collision>
      <xacro:Box_inertial_matrix m="${base_link_front_m}" l="0.45" w="0.26" h="0.25"/>
    </link>

    <joint name="base_link2base_footprint" type="fixed">
      <parent link="base_footprint" />
      <child link="base_link" />
      <origin xyz="0 0 ${earth_space + base_link_height / 2 }" />
    </joint>

    <joint name="base_link2base_link_back" type="fixed">
      <parent link="base_link" />
      <child link="base_link_back" />
      <origin xyz="-0.575 0 0" />
    </joint>

    <joint name="base_link2base_link_front" type="fixed">
      <parent link="base_link" />
      <child link="base_link_front" />
      <origin xyz="0.6 0 0" />
    </joint>

    <gazebo reference="base_link">
      <material>Gazebo/Yellow</material>
    </gazebo>
    <gazebo reference="base_link_back">
      <material>Gazebo/Yellow</material>
    </gazebo>
    <gazebo reference="base_link_front">
      <material>Gazebo/Yellow</material>
    </gazebo>

    <!-- 驱动轮（后轮） -->
    <!-- 轮子属性 -->
    <xacro:property name="wheel_radius" value="0.22" /><!-- 半径 -->
    <xacro:property name="wheel_length" value="0.18" /><!-- 宽度 -->
    <xacro:property name="wheel_m" value="1" /> <!-- 质量  -->
    <!-- 驱动轮宏实现 -->
    <link name="backshaft">
      <visual>
        <geometry>
          <cylinder radius="0.03" length="0.8" />
        </geometry>
        <origin xyz="0 0 0" rpy="${PI/2} 0 0" />
        <material name="grey">
          <color rgba="0.8 0.8 0.8 1" />
        </material>
      </visual>
      <collision>
        <geometry>
        <cylinder radius="0.03" length="0.8" />
        </geometry>
        <origin xyz="0 0 0" rpy="${PI/2} 0 0" />
      </collision>
      <xacro:cylinder_inertial_matrix m="0.001" r="0.03" h="0.8" />
    </link>

    <gazebo reference="backshaft">
      <material>Gazebo/Grey</material>
        <mu1>100</mu1>
        <mu2>100</mu2>
    </gazebo>

    <xacro:macro name="add_backwheels" params="name flag">
      <link name="${name}_backwheel">
        <visual>
          <geometry>
            <cylinder radius="${wheel_radius}" length="${wheel_length}" />
          </geometry>
          <origin xyz="0.0 0.0 0.0" rpy="${PI / 2} 0.0 0.0" />
          <material name="black" />
        </visual>
        <collision>
          <geometry>
            <cylinder radius="${wheel_radius}" length="${wheel_length}" />
          </geometry>
          <origin xyz="0.0 0.0 0.0" rpy="${PI / 2} 0.0 0.0" />
        </collision>
        <xacro:cylinder_inertial_matrix m="${wheel_m}" r="${wheel_radius}" h="${wheel_length}" />
      </link>

      <joint name="${name}_backwheel2base_link" type="continuous">
        <parent link="backshaft" />
        <child link="${name}_backwheel" />
        <!-- <origin xyz="0 ${flag * 0.4175} 0.0" /> -->
        <origin xyz="0 ${flag * 0.4} 0.0" />
        <axis xyz="0 1 0" />
      </joint>

      <gazebo reference="${name}_backwheel">
        <material>Gazebo/Black</material>
        <mu1>10000</mu1>
        <mu2>10000</mu2>
      </gazebo>

    </xacro:macro>

    <joint name="backshaft2base_link" type="fixed">
        <parent link="base_link" />
        <child link="backshaft" />
        <origin xyz="-0.635 0.0 ${-(earth_space + base_link_height / 2 - wheel_radius) }" />
        <axis xyz="0 0 0" />
    </joint>

    <xacro:add_backwheels name="left" flag="1" />
    <xacro:add_backwheels name="right" flag="-1" />

    <!-- 转向轮（前轮） -->
    <xacro:property name="degrees_28" value="0.49"/>
    <xacro:property name="servo_stall_torque" value="1000000.0"/>
    <xacro:property name="servo_no_load_speed" value="10000.0"/>
    <!-- 转向轮实现 -->
    <link name="frontshaft">
      <visual>
        <geometry>
          <cylinder radius="0.03" length="0.8" />
        </geometry>
        <origin xyz="0 0 0" rpy="${PI/2} 0 0" />
        <material name="grey">
          <color rgba="0.8 0.8 0.8 1" />
        </material>
      </visual>
      <collision>
        <geometry>
        <cylinder radius="0.03" length="0.8" />
        </geometry>
        <origin xyz="0 0 0" rpy="${PI/2} 0 0" />
      </collision>
      <xacro:cylinder_inertial_matrix m="0.001" r="0.03" h="0.8" />
    </link>

    <gazebo reference="frontshaft">
      <material>Gazebo/Grey</material>
      <mu1>100</mu1>
      <mu2>100</mu2>
    </gazebo>

  	<link name="left_bridge">
      <visual>
        <geometry>
          <cylinder radius="0.04" length="0.1" />
        </geometry>
        <origin xyz="0 0 0" rpy="${PI/2} 0 0" />
        <material name="red">
          <color rgba="1.0 0.0 0.0 1" />
        </material>
      </visual>
      <collision>
        <geometry>
        <cylinder radius="0.04" length="0.1" />
        </geometry>
        <origin xyz="0 0 0" rpy="${PI/2} 0 0" />
      </collision>
      <xacro:cylinder_inertial_matrix m="0.001" r="0.04" h="0.1" />
    </link>

    <gazebo reference="left_bridge">
      <material>Gazebo/Grey</material>
      <mu1>100</mu1>
      <mu2>100</mu2>
    </gazebo>

  	<link name="right_bridge">
      <visual>
        <geometry>
          <cylinder radius="0.04" length="0.1" />
        </geometry>
        <origin xyz="0 0 0" rpy="${PI/2} 0 0" />
        <material name="red">
          <color rgba="1.0 0.0 0.0 1" />
        </material>
      </visual>
      <collision>
        <geometry>
        <cylinder radius="0.04" length="0.1" />
        </geometry>
        <origin xyz="0 0 0" rpy="${PI/2} 0 0" />
      </collision>
      <xacro:cylinder_inertial_matrix m="0.001" r="0.04" h="0.1" />
    </link>

    <gazebo reference="right_bridge">
      <material>Gazebo/Grey</material>
      <mu1>100</mu1>
      <mu2>100</mu2>
    </gazebo>

    <xacro:macro name="add_frontwheels" params="name flag">
      <link name="${name}_frontwheel">
        <visual>
          <geometry>
            <cylinder radius="${wheel_radius}" length="${wheel_length}" />
          </geometry>
          <origin xyz="0.0 0.0 0.0" rpy="${PI / 2} 0.0 0.0" />
          <material name="black" />
        </visual>
        <collision>
          <geometry>
            <cylinder radius="${wheel_radius}" length="${wheel_length}" />
          </geometry>
          <origin xyz="0.0 0.0 0.0" rpy="${PI / 2} 0.0 0.0" />
        </collision>
        <xacro:cylinder_inertial_matrix m="${wheel_m}" r="${wheel_radius}" h="${wheel_length}" />
      </link>

      <gazebo reference="${name}_frontwheel">
        <material>Gazebo/Black</material>
        <mu1>0.1</mu1>
        <mu2>0.1</mu2>
      </gazebo>

      <joint name="${name}_bridge2base_link" type="revolute">
        <parent link="frontshaft" />
        <child link="${name}_bridge" />
        <origin xyz="0 ${flag * 0.4175} 0.0" />
        <axis xyz="0 0 1" />
        <limit lower="${-degrees_28}" upper="${degrees_28}"
             effort="${servo_stall_torque}" velocity="${servo_no_load_speed}"/>
      </joint>

      <joint name="${name}_frontwheel2${name}_bridge" type="continuous">
        <parent link="${name}_bridge" />
        <child link="${name}_frontwheel" />
        <origin xyz="0.0 0.0 0.0" />
        <axis xyz="0 1 0" />
      </joint>
    </xacro:macro>

    <joint name="frontshaft2base_link" type="fixed">
        <parent link="base_link" />
        <child link="frontshaft" />
        <origin xyz="0.685 0.0 ${-(earth_space + base_link_height / 2 - wheel_radius) }" />
        <axis xyz="0 0 0" />
    </joint>

    <xacro:add_frontwheels name="left" flag="1" />
    <xacro:add_frontwheels name="right" flag="-1" />

    <!-- IMU支撑架实现 -->
    <xacro:property name="frame0_m" value="0.01" />
    <link name="frame0">
      <visual>
        <geometry>
          <box size="0.32 0.835 0.115" />
        </geometry>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <material name="white">
          <color rgba="1.0 1.0 1.0 1.0" />
        </material>
      </visual>
      <collision>
        <geometry>
          <box size="0.32 0.835 0.115" />
        </geometry>
        <origin xyz="0 0 0" rpy="0 0 0" />
      </collision>
      <xacro:Box_inertial_matrix m="${frame0_m}" l="0.32" w="0.835" h="0.115"/>
    </link>

    <joint name="frame02base_link" type="fixed">
      <parent link="base_link" />
      <child link="frame0" />
      <origin xyz="0.215 0 0.1825" />
    </joint>   

    <gazebo reference="frame0">
      <material>Gazebo/White</material>
    </gazebo>

    <!-- 激光雷达支架 -->
    <link name="frame1">
      <visual>
        <geometry>
          <cylinder radius="0.02" length="0.445" />
        </geometry>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <material name="grey">
          <color rgba="0.8 0.8 0.8 1" />
        </material>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="0.02" length="0.445" />
        </geometry>
        <origin xyz="0 0 0" rpy="0 0 0" />
      </collision>
      <xacro:cylinder_inertial_matrix m="0.01" r="0.02" h="0.445" />
    </link>

    <joint name="frame12base_link" type="fixed">
      <parent link="base_link" />
      <child link="frame1" />
      <origin xyz="0.0 0.0 0.3475" />
    </joint>  

    <gazebo reference="frame1">
      <material>Gazebo/Yellow</material>
    </gazebo>

    <!-- 摄像头 -->
    <link name="camera">
      <visual>
        <geometry>
          <box size="0.05 0.2 0.08" />
        </geometry>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <material name="blue">
          <color rgba="0.0 0.0 1.0 1.0" />
        </material>
      </visual>
      <collision>
        <geometry>
          <box size="0.05 0.2 0.08" />
        </geometry>
        <origin xyz="0 0 0" rpy="0 0 0" />
      </collision>
      <xacro:Box_inertial_matrix m="0.2" l="0.05" w="0.2" h="0.08"/>
    </link> 

    <gazebo reference="camera">
      <material>Gazebo/Blue</material>
    </gazebo>

    <joint name="camera_joint" type="fixed">
      <origin xyz="0.435 0 0.1175" rpy="0 0.18 0" />
      <parent link="frame0"/>
      <child link="camera"/>
    </joint>

  <!-- ros2_control 配置：为需要控制的 joint 指定接口 -->
  <ros2_control name="carlike_robot_control" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>

    <!-- 驱动轮（速度控制） -->
    <joint name="left_backwheel2base_link">
      <command_interface name="velocity">
        <param name="min">-10</param>
        <param name="max">10</param>
      </command_interface>
      <state_interface name="position" />
      <state_interface name="velocity" />
    </joint>

    <joint name="right_backwheel2base_link">
      <command_interface name="velocity">
        <param name="min">-10</param>
        <param name="max">10</param>
      </command_interface>
      <state_interface name="position" />
      <state_interface name="velocity" />
    </joint>

    <!-- 前轮转向（位置控制） -->
    <joint name="left_bridge2base_link">
      <command_interface name="position" />
      <state_interface name="position" />
    </joint>

    <joint name="right_bridge2base_link">
      <command_interface name="position" />
      <state_interface name="position" />
    </joint>
  </ros2_control>

  <gazebo>
    <plugin name="gazebo_ros2_control" filename="libgazebo_ros2_control.so">
      <parameters>$(find carlike_robot_description)/config/controllers.yaml</parameters>
        <ros>
          <remapping>/ackermann_steering_controller/controller_state:=/controller_state</remapping>
          <remapping>/ackermann_steering_controller/odometry:=/odom</remapping>
          <remapping>/ackermann_steering_controller/reference_unstamped:=/cmd_vel</remapping>
          <remapping>/ackermann_steering_controller/tf_odometry:=/tf</remapping>
          <remapping>/ackermann_steering_controller/transition_event:=/transition_event</remapping>
        </ros>
    </plugin>
  </gazebo>
</robot>